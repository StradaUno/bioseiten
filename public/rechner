<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Reel Preiskalkulator</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f0f0f0; min-height: 100vh; display: flex; align-items: flex-start; justify-content: center; padding: 24px 16px; }
.card { background: #fff; border-radius: 20px; padding: 20px; width: 100%; max-width: 400px; border: 1px solid #e0e0e0; }
.top-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18px; }
.card-title { font-size: 17px; font-weight: 600; color: #111; }
.section-label { font-size: 11px; font-weight: 600; color: #999; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 8px; }
.platform-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 16px; }
.plat-btn { display: flex; align-items: center; justify-content: center; gap: 7px; padding: 11px 10px; border-radius: 12px; border: 1.5px solid #d0d0d0; background: #fafafa; color: #333; font-size: 14px; font-weight: 500; cursor: pointer; transition: all 0.15s; }
.plat-btn.active { border-color: #111; background: #fff; color: #111; box-shadow: 0 1px 4px rgba(0,0,0,0.08); }
.format-seg { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin-bottom: 16px; }
.fmt-btn { padding: 9px 4px; border-radius: 10px; border: 1.5px solid #d0d0d0; background: #fafafa; color: #333; font-size: 12px; font-weight: 500; cursor: pointer; transition: all 0.15s; }
.fmt-btn.active { border-color: #111; background: #fff; color: #111; font-weight: 600; box-shadow: 0 1px 4px rgba(0,0,0,0.08); }
.inputs-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 16px; }
.input-group label { font-size: 11px; color: #999; margin-bottom: 4px; display: block; }
.input-group input { width: 100%; padding: 9px 10px; border-radius: 8px; border: 1px solid #e0e0e0; background: #f5f5f5; color: #111; font-size: 15px; outline: none; transition: border-color 0.2s; }
.input-group input:focus { border-color: #22c55e; background: #fff; }
.divider { border: none; border-top: 1px solid #efefef; margin: 4px 0 14px; }
.extras-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; margin-bottom: 16px; }
.extra-item { display: flex; flex-direction: column; align-items: center; gap: 6px; background: #f5f5f5; border-radius: 10px; padding: 10px 6px; }
.extra-item span { font-size: 11px; color: #666; text-align: center; line-height: 1.3; }
.toggle { position: relative; width: 36px; height: 20px; flex-shrink: 0; }
.toggle input { opacity: 0; width: 0; height: 0; }
.slider { position: absolute; inset: 0; background: #ccc; border-radius: 999px; cursor: pointer; transition: 0.2s; }
.slider:before { content: ''; position: absolute; width: 14px; height: 14px; left: 3px; top: 3px; background: white; border-radius: 50%; transition: 0.2s; }
.toggle input:checked + .slider { background: #22c55e; }
.toggle input:checked + .slider:before { transform: translateX(16px); }
.result-box { background: #f5f5f5; border-radius: 12px; padding: 14px 16px; display: flex; justify-content: space-between; align-items: center; }
.result-label { font-size: 12px; color: #999; }
.result-sub { font-size: 11px; color: #bbb; margin-top: 2px; }
.result-value { font-size: 28px; font-weight: 700; color: #111; }
</style>
</head>
<body>
<div class="card">
  <div class="top-row">
    <span class="card-title">Preiskalkulator</span>
  </div>

  <div class="section-label">Plattform</div>
  <div class="platform-row">
    <button class="plat-btn active" data-val="instagram" onclick="setPlatform(this)">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#111" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="#111" stroke="none"/></svg>
      Instagram
    </button>
    <button class="plat-btn" data-val="tiktok" onclick="setPlatform(this)">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="#333"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/></svg>
      TikTok
    </button>
  </div>

  <div class="section-label">Format</div>
  <div class="format-seg">
    <button class="fmt-btn active" data-val="reel30" onclick="setFormat(this)">Reel 30s</button>
    <button class="fmt-btn" data-val="reel60" onclick="setFormat(this)">Reel 60s</button>
    <button class="fmt-btn" data-val="reel90" onclick="setFormat(this)">Reel 90s</button>
    <button class="fmt-btn" data-val="story" onclick="setFormat(this)">Story</button>
    <button class="fmt-btn" data-val="ugc" onclick="setFormat(this)">UGC</button>
    <button class="fmt-btn" data-val="reel3min" onclick="setFormat(this)">Reel 3min+</button>
  </div>

  <div class="inputs-grid">
    <div class="input-group"><label>Follower</label><input type="number" id="follower" value="84200" oninput="calc()"></div>
    <div class="input-group"><label>Engagement (%)</label><input type="number" id="engagement" value="4.9" step="0.1" oninput="calc()"></div>
    <div class="input-group"><label>Aufwand (Std.)</label><input type="number" id="stunden" value="2" min="1" oninput="calc()"></div>
    <div class="input-group"><label>Revisionen</label><input type="number" id="revisionen" value="1" min="1" oninput="calc()"></div>
  </div>

  <hr class="divider">
  <div class="section-label">Extras</div>
  <div class="extras-grid">
    <div class="extra-item">
      <label class="toggle"><input type="checkbox" id="exkl" onchange="calc()"><span class="slider"></span></label>
      <span>Exklusivität 30 Tage</span>
    </div>
    <div class="extra-item">
      <label class="toggle"><input type="checkbox" id="white" onchange="calc()"><span class="slider"></span></label>
      <span>Whitelisting</span>
    </div>
    <div class="extra-item">
      <label class="toggle"><input type="checkbox" id="nutz" onchange="calc()"><span class="slider"></span></label>
      <span>Nutzungsrechte</span>
    </div>
  </div>

  <div class="result-box">
    <div>
      <div class="result-label">Empfehlung</div>
      <div class="result-sub" id="resultSub">bei 2h Aufwand</div>
    </div>
    <div class="result-value" id="resultVal">≈ €270</div>
  </div>
</div>

<script>
const formatFaktor = { reel30:1.0, reel60:1.3, reel90:1.5, story:0.5, ugc:0.8, reel3min:2.0 };
let currentFormat = 'reel30';
function setPlatform(btn) {
  document.querySelectorAll('.plat-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active'); calc();
}
function setFormat(btn) {
  document.querySelectorAll('.fmt-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active'); currentFormat = btn.dataset.val; calc();
}
function calc() {
  const follower = parseFloat(document.getElementById('follower').value)||0;
  const engagement = parseFloat(document.getElementById('engagement').value)||0;
  const stunden = parseFloat(document.getElementById('stunden').value)||1;
  const rev = parseFloat(document.getElementById('revisionen').value)||1;
  const exkl = document.getElementById('exkl').checked;
  const white = document.getElementById('white').checked;
  const nutz = document.getElementById('nutz').checked;
  const fFaktor = formatFaktor[currentFormat]||1.0;
  const engBonus = 1.0+(engagement>3.0?(engagement-3.0)*0.1:0.0);
  let basis = (follower/1000)*10.0*fFaktor*engBonus;
  basis += stunden*80.0;
  basis += (rev-1)*50.0;
  if(exkl) basis*=1.3;
  if(white) basis*=1.25;
  if(nutz) basis*=1.2;
  document.getElementById('resultVal').textContent='≈ €'+Math.round(basis).toLocaleString('de-DE');
  document.getElementById('resultSub').textContent='bei '+stunden+'h Aufwand';
}
calc();
</script>
</body>
</html>
[[redirects]]
  from = "/rechner"
  to = "/rechner/index.html"
  status = 200
